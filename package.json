    "test:phase4:production-readiness": "vitest run tests/phase4-integration/production-readiness --reporter=verbose",
    "test:phase4:all": "npm run test:phase4",
    "test:phase4:setup": "node tests/phase4-integration/scripts/setup-test-environment.js",
    "test:phase4:cleanup": "node tests/phase4-integration/scripts/cleanup-test-environment.js",
    "test:phase4:report": "node tests/phase4-integration/scripts/generate-reports.js",
    "test:malaysian:full": "tsx tests/malaysian-features/comprehensive-test-suite.js",
    "test:performance:benchmark": "tsx tests/performance/malaysian-performance-benchmark.js",
    "test:cultural:validation": "tsx tests/malaysian-features/comprehensive-test-suite.js",
    "test:load:malaysian": "tsx tests/performance/malaysian-performance-benchmark.js",
    "recovery": "tsx scripts/data-recovery.ts",
    "generate-thumbnails": "tsx scripts/utils/generate-thumbnails.ts",
    "env:status": "node scripts/utils/switch-env.js status",
    "env:local": "node scripts/utils/switch-env.js local",
    "env:production": "node scripts/utils/switch-env.js production",
    "dev:local": "npm run env:local && npm run dev",
    "dev:production": "npm run env:production && npm run dev",
    "deploy:validate:malaysian": "tsx scripts/deployment/malaysian-deployment-validator.js pre-deployment",
    "deploy:stage1:backend": "echo \"Backend deployment - already complete\"",
    "deploy:stage2:frontend": "npm run build && echo \"Frontend deployment ready\"",
    "deploy:stage3:monitoring": "node scripts/deployment/malaysian-deployment-validator.js post-deployment",
    "deploy:verify:complete": "tsx scripts/deployment/malaysian-deployment-validator.js post-deployment",
    "monitor:performance:start": "echo \"Performance monitoring active\"",
    "monitor:metrics:realtime": "echo \"Real-time metrics dashboard\"",
    "monitor:alerts:setup": "echo \"Alert configuration complete\"",
    "playwright-mcp:debug": "npx @playwright/mcp --config ./playwright-mcp-debug.config.json",
    "playwright-mcp:debug-trace": "npx @playwright/mcp --config ./playwright-mcp-debug.config.json --save-trace",
    "playwright-mcp:debug-console": "PWDEBUG=console npx @playwright/mcp --config ./playwright-mcp-debug.config.json",
    "playwright-mcp:debug-verbose": "DEBUG=pw:api PWDEBUG=console npx @playwright/mcp --config ./playwright-mcp-debug.config.json --save-trace",
