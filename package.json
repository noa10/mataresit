    "test:phase4": "chmod +x tests/phase4-integration/scripts/run-integration-tests.sh && tests/phase4-integration/scripts/run-integration-tests.sh",
    "test:phase4:integration": "vitest run tests/phase4-integration/integration --reporter=verbose",
    "test:phase4:performance": "vitest run tests/phase4-integration/performance --reporter=verbose",
    "test:monitoring:performance": "node scripts/monitoring/simple-performance-check.js",
    "test:monitoring:security": "node scripts/monitoring/simple-security-check.js",
