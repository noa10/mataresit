  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts --reporter=verbose",
    "test:integration": "vitest run tests/integration --reporter=verbose",
    "test:integration:all": "node tests/integration/stripe-integration.test.js && node tests/integration/gemini-function.test.js && node tests/integration/test-payment-flow.js",
    "test:manual": "echo \"Manual tests available in tests/manual/ directory\"",
    "test:malaysian:basic": "tsx tests/malaysian-features/basic-validation-test.js",
    "test:alerting": "chmod +x tests/alerting/run-tests.sh && tests/alerting/run-tests.sh",
    "test:alerting:unit": "vitest run tests/alerting/unit",
    "test:alerting:integration": "vitest run tests/alerting/integration",
    "test:alerting:e2e": "playwright test tests/alerting/e2e",
    "test:alerting:performance": "node tests/alerting/performance/alert-volume-performance.test.js",
    "test:alerting:database": "vitest run tests/alerting/database",
    "test:alerting:all": "npm run test:alerting -- --all",
    "test:unit:alerting": "vitest run tests/alerting/unit --reporter=verbose",
    "test:integration:alerting": "vitest run tests/alerting/integration --reporter=verbose",
