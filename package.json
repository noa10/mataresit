    "supabase:push:dry": "supabase db push --dry-run",
    "supabase:diff": "supabase db diff --schema public",
    "supabase:migrate:list": "supabase migration list",
    "supabase:migrate:new": "supabase migration new",
    "supabase:migrate:repair": "supabase migration repair"
  },
